		"devdoc": {
			"details": "This contract intentionally has no access control. Records are      caller-submitted data and do not, by themselves, prove Chainlink CRE      provenance, source-data authenticity, or zkVerify verification.",
			"events": {
				"ClimateAlertRecorded(uint256,string,uint8,int256,bytes32,uint256,address)": {
					"details": "publisher is msg.sender and evidenceHash is an unverified reference."
				},
				"EnvironmentalDecisionAlertRecorded(uint256,string,string,uint256,uint8,uint8,bytes32,uint256,address)": {
					"details": "proofHash is stored as metadata; no proof verification occurs here."
				},
				"HealthAlertRecorded(uint256,string,string,string,uint256,string,uint256)": {
					"details": "This event does not assert who produced or approved the source data."
				}
			},
			"kind": "dev",
			"methods": {
				"onReport(bytes)": {
					"details": "This entry point is permissionless and does not validate a CRE      forwarder or report signature."
				},
				"recordEnvironmentalDecisionAlert(string,string,string,uint256,uint8,uint8,bytes32,string)": {
					"details": "A nonzero proofHash is required as a reference, but is not verified."
				}
			},
			"title": "HealthAlertRegistry",
			"version": 1
		},
		"userdoc": {
			"events": {
				"ClimateAlertRecorded(uint256,string,uint8,int256,bytes32,uint256,address)": {
					"notice": "Emitted when a caller submits a climate alert."
				},
				"EnvironmentalDecisionAlertRecorded(uint256,string,string,uint256,uint8,uint8,bytes32,uint256,address)": {
					"notice": "Emitted when a caller submits a combined environmental decision."
				},
				"HealthAlertRecorded(uint256,string,string,string,uint256,string,uint256)": {
					"notice": "Emitted when a health alert is appended."
				}
			},
			"kind": "user",
			"methods": {
				"onReport(bytes)": {
					"notice": "Decodes and stores the health-alert payload used by the demo CRE         workflow."
				},
				"recordAlert(string,string,string,uint256,string)": {
					"notice": "Appends a health alert submitted directly by the caller."
				},
				"recordClimateAlert(string,int256,uint8,uint8,uint8,string,string,bytes32)": {
					"notice": "Appends caller-supplied climate decision metadata."
				},
				"recordEnvironmentalDecisionAlert(string,string,string,uint256,uint8,uint8,bytes32,string)": {
					"notice": "Appends caller-supplied Environmental Decision metadata."
				}
